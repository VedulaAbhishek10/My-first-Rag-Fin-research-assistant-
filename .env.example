# ──────────────────────────────────────────────────────────────────────────────
# Financial Research Assistant — Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored — never commit real credentials.
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Financial Research Assistant"
APP_VERSION="0.1.0"
DEBUG=false
LOG_LEVEL=INFO

# ── API / CORS ────────────────────────────────────────────────────────────────
# Add your frontend origin here if it's different from the default.
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Ollama (LLM) ──────────────────────────────────────────────────────────────
# Make sure Ollama is running: `ollama serve`
# Pull the model first: `ollama pull qwen2.5-coder:3b-instruct`
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:3b-instruct
OLLAMA_TIMEOUT=120

# ── Embeddings (HuggingFace) ──────────────────────────────────────────────────
# The model is downloaded automatically on first use (~130 MB).
# Change EMBEDDING_DEVICE to "cuda" if you have an NVIDIA GPU.
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32

# ── ChromaDB (Vector Store) ───────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=financial_docs

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite for local development.
# To switch to PostgreSQL: DATABASE_URL=postgresql://user:pass@localhost/dbname
DATABASE_URL=sqlite:///./data/financial_rag.db

# ── File Storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=50

# ── Chunking ──────────────────────────────────────────────────────────────────
# chunk_size: characters per chunk (~100-150 words at 512 chars)
# chunk_overlap: shared characters between adjacent chunks
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Retrieval ─────────────────────────────────────────────────────────────────
# How many chunks to retrieve from ChromaDB per query.
RETRIEVAL_TOP_K=5
